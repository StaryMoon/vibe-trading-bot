# Copy to .env for local use. Never commit .env.

# Modes: paper, sandbox, live. Keep paper/sandbox until all live gates pass.
VIBE_TRADER_MODE=paper

# Binance keys. Use Spot Testnet keys for sandbox and production spot keys only
# for configs/live_binance_spot_small.yaml after you accept real-money risk.
BINANCE_API_KEY=
BINANCE_SECRET=

# Optional AI review. If unset, the bot writes a deterministic local review.
VIBE_TRADER_AI_PROVIDER=local
OPENAI_API_KEY=

# Live trading is intentionally hard to enable.
LIVE_TRADING_ACK=false
LIVE_TRADING_CONFIRM_TEXT=
MAX_LIVE_EQUITY=0
